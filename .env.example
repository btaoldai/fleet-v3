# Configuration du daemon bot-root (toutes optionnelles — valeurs par défaut affichées).
# Aucune donnée secrète ici : les tokens Discord des bots sont gérés séparément
# (Docker secrets / fichiers *_FILE), jamais dans ce fichier.

# Chemin du socket Unix IPC sur lequel bot-root écoute.
BOT_ROOT_SOCKET=/tmp/bot-root.sock

# URL du serveur Ollama.
OLLAMA_URL=http://ollama:11434

# Timeout HTTP des requêtes Ollama, en secondes (généreux pour l'offload RAM).
OLLAMA_TIMEOUT_SECS=240

# Cooldown de settling appliqué à chaque swap de modèle, en secondes.
BOT_ROOT_SWAP_COOLDOWN_SECS=2

# Modèle d'escalade de Winston, si tiré sur la machine (sinon Winston reste sur
# son modèle par défaut). Décommenter selon la VRAM/RAM disponible.
# WINSTON_ESCALATION_MODEL=qwen2.5:14b

# Niveau de log (lu par tracing-subscriber EnvFilter).
# RUST_LOG=info
